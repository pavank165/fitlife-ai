{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile and statistics",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "steps": { "type": "number" },
        "stepGoal": { "type": "number" },
        "calories": { "type": "number" },
        "calorieGoal": { "type": "number" },
        "water": { "type": "number" },
        "waterGoal": { "type": "number" },
        "weight": { "type": "number" },
        "weightGoal": { "type": "number" },
        "workoutsCompleted": { "type": "number" },
        "streak": { "type": "number" }
      },
      "required": ["uid", "email"]
    },
    "CompletedWorkout": {
      "title": "CompletedWorkout",
      "description": "A workout session completed by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "workoutId": { "type": "string" },
        "workoutTitle": { "type": "string" },
        "durationSeconds": { "type": "number" },
        "intensity": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "timestamp": { "type": "number" },
        "caloriesBurned": { "type": "number" }
      },
      "required": ["userId", "workoutId", "workoutTitle", "durationSeconds", "intensity", "timestamp", "caloriesBurned"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data"
    },
    "/users/{userId}/completedWorkouts/{workoutId}": {
      "schema": "CompletedWorkout",
      "description": "History of workouts for a user"
    }
  }
}
