<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.FitLife.Button" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/primary_color</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:textAllCaps">true</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingVertical">16dp</item>
    </style>

    <style name="Widget.FitLife.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/white</item>
        <item name="strokeColor">@color/primary_color</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">12dp</item>
    </style>
</resources>
